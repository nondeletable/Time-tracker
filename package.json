{
  "name": "time-tracker",
  "version": "1.0.0",
  "description": "Desktop time tracker for two users on a shared LAN",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "playwright-core": "^1.61.0"
  },
  "build": {
    "appId": "com.timetracker.app",
    "productName": "Time Tracker",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "nsis",
      "executableName": "time-tracker"
    },
    "nsis": {
      "artifactName": "${name}-${version}-setup.${ext}",
      "shortcutName": "${productName}",
      "createDesktopShortcut": "always"
    }
  }
}
